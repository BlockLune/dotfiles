// ------------------------
// BlockLune's Zed Settings
// ------------------------
{
  "autosave": "on_window_change",
  "buffer_font_size": 14,
  "buffer_font_family": "FiraCode Nerd Font",
  "format_on_save": "off",
  "icon_theme": "Soft Charmed Icons",
  "indent_guides": {
    "enabled": true,
    "active_line_width": 2,
    "coloring": "indent_aware"
  },
  "outline_panel": {
    "dock": "right"
  },
  "relative_line_numbers": "enabled",
  "tab_size": 2,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Vesper Blur"
  },
  "ui_font_size": 14,
  "vim_mode": true,
  "vertical_scroll_margin": 10,
  "wrap_guides": [
    80,
    100,
    120
  ]
}
