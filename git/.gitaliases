# -----------------------------------
# BlockLune's aliases of git commands
# -----------------------------------

# git add
alias ga="git add --verbose"
alias gaa="git add --all --verbose"
alias gap="git add --patch"

# git branch
alias gb="git branch"

# git blame
alias gblame="git blame"

# git commit
alias gc!="git commit --verbose --amend"
alias gc="git commit --verbose"

# git checkout
alias gcb="git checkout -b"
alias gco="git checkout"

# git clone
alias gcl1="git clone --recurse-submodules --depth=1"
alias gcl="git clone --recurse-submodules"

# git cherry-pick
alias gcp="git cherry-pick"

# git diff
gd() {
  if command -v difft &>/dev/null; then
    git -c diff.external=difft diff "$@"
  else
    echo "Difft not found. Falling back to 'git diff'."
    git diff "$@"
  fi
}
alias gds="git diff --stat"
gdv() {
  if command -v nvim &>/dev/null; then
    git -c diff.tool=nvimdiff -c difftool.prompt=false -c "difftool.nvimdiff.cmd=nvim -d \$LOCAL \$REMOTE" difftool "$@"
  else
    echo "Nvim not found. Falling back to 'git diff'."
    git diff "$@"
  fi
}

# git fetch
alias gf="git fetch"

# git pull
alias gl="git pull"

# git log
glog() {
  if command -v serie &>/dev/null; then
    serie -o topo -i head -n 100 "$@"
  else
    echo "Serie not found. Falling back to 'git log ...'."
    git log --graph --pretty=format:'%C(magenta)%h %C(white) %an %ar%C(auto) %D%n%s%n' "$@"
  fi
}

# git merge
alias gm="git merge"

# git push
alias gp="git push"

# git rebase
alias grb="git rebase"

# git remote
alias gremote="git remote"

# git restore
alias grestore="git restore"

# git reflog
alias grf="git reflog"

# git reset
alias grh="git reset --hard"

# git show
alias gshow="git show"

# git status
alias gss="git status --short"

# git stash
alias gstash="git stash"

# utility functions
git-authors() {
  if [[ $# -eq 0 ]]; then
    echo "Usage: git-authors <file> [more files...]"
      return 1
  fi
  git log --follow --format='%aN <%aE>' -- "$@" | sort -u
}
alias gauthors="git-authors"
